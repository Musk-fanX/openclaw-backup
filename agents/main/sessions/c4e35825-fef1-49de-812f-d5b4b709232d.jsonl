ase64,UklGRigAAABXQVZFZm10IBIAAAABAAEAQB8AAEAfAAABAAgAZGF0YQ')\n        };\n        \n        // 初始化\n        this.init();\n        this.setupEventListeners();\n        this.createBricks();\n        this.draw();\n    }\n    \n    init() {\n        // 创建简单的音效（基础音调）\n        this.createSoundEffects();\n    }\n    \n    createSoundEffects() {\n        // 创建简单的音效\n        const createTone = (frequency, duration) => {\n            const audioContext = new (window.AudioContext || window.webkitAudioContext)();\n            const oscillator = audioContext.createOscillator();\n            const gainNode = audioContext.createGain();\n            \n            oscillator.connect(gainNode);\n            gainNode.connect(audioContext.destination);\n            \n            oscillator.frequency.value = frequency;\n            oscillator.type = 'sine';\n            \n            gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);\n            gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + duration);\n            \n            oscillator.start(audioContext.currentTime);\n            oscillator.stop(audioContext.currentTime + duration);\n        };\n        \n        // 绑定音效\n        this.playSound = (type) => {\n            if (!this.soundEnabled) return;\n            \n            try {\n                switch(type) {\n                    case 'hit':\n                        createTone(440, 0.1); // A4\n                        break;\n                    case 'brick':\n                        createTone(523.25, 0.2); // C5\n                        break;\n                    case 'life':\n                        createTone(349.23, 0.3); // F4\n                        break;\n                    case 'win':\n                        createTone(659.25, 0.5); // E5\n                        break;\n                }\n            } catch (e) {\n                console.log('音效播放失败:', e);\n            }\n        };\n    }\n    \n    createBricks() {\n        this.bricks = [];\n        for (let c = 0; c < this.brickColumnCount; c++) {\n            this.bricks[c] = [];\n            for (let r = 0; r < this.brickRowCount; r++) {\n                // 随机生成不同类型的方块\n                let health = 1;\n                let color = '#4361ee';\n                let scoreValue = 10;\n                \n                // 特殊方块\n                if (r === 0 && c % 3 === 0) { // 红色方块 - 需要击中两次\n                    health = 2;\n                    color = '#f72585';\n                } else if (r === 1 && c % 4 === 0) { // 金色方块 - 高分\n                    scoreValue = 20;\n                    color = '#ffd166';\n                } else if (r === 2 && c % 5 === 0) { // 绿色方块 - 普通\n                    color = '#06d6a0';\n                }\n                \n                this.bricks[c][r] = {\n                    x: c * (this.brickWidth + this.brickPadding) + this.brickOffsetLeft,\n                    y: r * (this.brickHeight + this.brickPadding) + this.brickOffsetTop,\n                    width: this.brickWidth,\n                    height: this.brickHeight,\n                    health: health,\n                    maxHealth: health,\n                    color: color,\n                    scoreValue: scoreValue,\n                    visible: true\n                };\n            }\n        }\n    }\n    \n    setupEventListeners() {\n        // 鼠标控制\n        this.canvas.addEventListener('mousemove', (e) => {\n            if (!this.gameRunning || this.gamePaused) return;\n            \n            const relativeX = e.clientX - this.canvas.getBoundingClientRect().left;\n            if (relativeX > 0 && relativeX < this.canvas.width) {\n                this.paddle.x = relativeX - this.paddle.width / 2;\n                \n                // 限制挡板不超出画布\n                if (this.paddle.x < 0) {\n                    this.paddle.x = 0;\n                }\n                if (this.paddle.x + this.paddle.width > this.canvas.width) {\n                    this.paddle.x = this.canvas.width - this.paddle.width;\n                }\n            }\n        });\n        \n        // 键盘控制\n        document.addEventListener('keydown', (e) => {\n            if (!this.gameRunning || this.gamePaused) return;\n            \n            if (e.key === 'ArrowLeft' || e.key === 'a') {\n                this.paddle.x -= this.paddle.speed;\n                if (this.paddle.x < 0) this.paddle.x = 0;\n            }\n            if (e.key === 'ArrowRight' || e.key === 'd') {\n                this.paddle.x += this.paddle.speed;\n                if (this.paddle.x + this.paddle.width > this.canvas.width) {\n                    this.paddle.x = this.canvas.width - this.paddle.width;\n                }\n            }\n        });\n    }\n    \n    drawBall() {\n        this.ctx.beginPath();\n        this.ctx.arc(this.ball.x, this.ball.y, this.ball.radius, 0, Math.PI * 2);\n        this.ctx.fillStyle = this.ball.color;\n        this.ctx.fill();\n        this.ctx.closePath();\n        \n        // 添加发光效果\n        this.ctx.shadowColor = this.ball.color;\n        this.ctx.shadowBlur = 15;\n        this.ctx.fill();\n        this.ctx.shadowBlur = 0;\n    }\n    \n    drawPaddle() {\n        this.ctx.beginPath();\n        this.ctx.roundRect(this.paddle.x, this.paddle.y, this.paddle.width, this.paddle.height, 10);\n        this.ctx.fillStyle = this.paddle.color;\n        this.ctx.fill();\n        this.ctx.closePath();\n        \n        // 添加渐变效果\n        const gradient = this.ctx.createLinearGradient(\n            this.paddle.x, this.paddle.y,\n            this.paddle.x, this.paddle.y + this.paddle.height\n        );\n        gradient.addColorStop(0, '#4cc9f0');\n        gradient.addColorStop(1, '#3a86ff');\n        this.ctx.fillStyle = gradient;\n        this.ctx.fill();\n    }\n    \n    drawBricks() {\n        for (let c = 0; c < this.brickColumnCount; c++) {\n            for (let r = 0; r < this.brickRowCount; r++) {\n                const brick = this.bricks[c][r];\n                if (brick.visible) {\n                    this.ctx.beginPath();\n                    this.ctx.roundRect(brick.x, brick.y, brick.width, brick.height, 5);\n                    \n                    // 根据生命值调整颜色\n                    let fillColor = brick.color;\n                    if (brick.health < brick.maxHealth) {\n                        // 受伤的方块变暗\n                        this.ctx.fillStyle = this.darkenColor(brick.color, 0.5);\n                    } else {\n                        this.ctx.fillStyle = fillColor;\n                    }\n                    \n                    this.ctx.fill();\n                    this.ctx.closePath();\n                    \n                    // 绘制方块边框\n                    this.ctx.strokeStyle = '#ffffff';\n                    this.ctx.lineWidth = 1;\n                    this.ctx.stroke();\n                    \n                    // 如果生命值大于1，显示生命值\n                    if (brick.maxHealth > 1) {\n                        this.ctx.fillStyle = '#ffffff';\n                        this.ctx.font = 'bold 12px Arial';\n                        this.ctx.textAlign = 'center';\n                        this.ctx.textBaseline = 'middle';\n                        this.ctx.fillText(\n                            brick.health,\n                            brick.x + brick.width / 2,\n                            brick.y + brick.height / 2\n                        );\n                    }\n                }\n            }\n        }\n    }\n    \n    darkenColor(color, factor) {\n        // 简单的颜色变暗函数\n        const hex = color.replace('#', '');\n        const r = parseInt(hex.substr(0, 2), 16);\n        const g = parseInt(hex.substr(2, 2), 16);\n        const b = parseInt(hex.substr(4, 2), 16);\n        \n        return `rgb(${Math.floor(r * factor)}, ${Math.floor(g * factor)}, ${Math.floor(b * factor)})`;\n    }\n    \n    draw() {\n        // 清空画布\n        this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);\n        \n        // 绘制背景网格\n        this.drawBackground();\n        \n        // 绘制游戏元素\n        this.drawBricks();\n        this.drawBall();\n        this.drawPaddle();\n        \n        // 如果游戏暂停，显示暂停文字\n        if (this.gamePaused && this.gameRunning) {\n            this.ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';\n            this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);\n            \n            this.ctx.fillStyle = '#ffffff';\n            this.ctx.font = 'bold 48px Arial';\n            this.ctx.textAlign = 'center';\n            this.ctx.fillText('游戏暂停', this.canvas.width / 2, this.canvas.height / 2);\n            \n            this.ctx.font = '24px Arial';\n            this.ctx.fillText('点击\"继续\"按钮或按空格键继续', this.canvas.width / 2, this.canvas.height / 2 + 50);\n        }\n        \n        // 更新UI显示\n        this.updateUI();\n    }\n    \n    drawBackground() {\n        // 绘制网格背景\n        this.ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';\n        this.ctx.lineWidth = 1;\n        \n        // 垂直线\n        for (let x = 0; x <= this.canvas.width; x += 50) {\n            this.ctx.beginPath();\n            this.ctx.moveTo(x, 0);\n            this.ctx.lineTo(x, this.canvas.height);\n            this.ctx.stroke();\n        }\n        \n        // 水平线\n        for (let y = 0; y <= this.canvas.height; y += 50) {\n            this.ctx.beginPath();\n            this.ctx.moveTo(0, y);\n            this.ctx.lineTo(this.canvas.width, y);\n            this.ctx.stroke();\n        }\n    }\n    \n    updateUI() {\n        document.getElementById('score').textContent = this.score;\n        document.getElementById('lives').textContent = this.lives;\n        document.getElementById('level').textContent = this.level;\n        document.getElementById('soundStatus').textContent = this.soundEnabled ? '开' : '关';\n    }\n    \n    collisionDetection() {\n        // 检查与方块的碰撞\n        for (let c = 0; c < this.brickColumnCount; c++) {\n            for (let r = 0; r < this.brickRowCount; r++) {\n                const brick = this.bricks[c][r];\n                if (brick.visible) {\n                    if (\n                        this.ball.x + this.ball.radius > brick.x &&\n                        this.ball.x - this.ball.radius < brick.x + brick.width &&\n                        this.ball.y + this.ball.radius > brick.y &&\n                        this.ball.y - this.ball.radius < brick.y + brick.height\n                    ) {\n                        this.playSound('brick');\n                        \n                        // 减少方块生命值\n                        brick.health--;\n                        if (brick.health <= 0) {\n                            brick.visible = false;\n                            this.score += brick.scoreValue;\n                            \n                            // 检查是否所有方块都被击碎\n                            this.checkLevelComplete();\n                        }\n                        \n                        // 根据碰撞位置改变小球方向\n                        const ballLeft = this.ball.x - this.ball.radius;\n                        const ballRight = this.ball.x + this.ball.radius;\n                        const ballTop = this.ball.y - this.ball.radius;\n                        const ballBottom = this.ball.y + this.ball.radius;\n                        \n                        const brickLeft = brick.x;\n                        const brickRight = brick.x + brick.width;\n                        const brickTop = brick.y;\n                        const brickBottom = brick.y + brick.height;\n                        \n                        // 判断从哪边碰撞\n                        const fromLeft = ballRight - brickLeft;\n                        const fromRight = brickRight - ballLeft;\n                        const fromTop = ballBottom - brickTop;\n                        const fromBottom = brickBottom - ballTop;\n                        \n                        const min = Math.min(fromLeft, fromRight, fromTop, fromBottom);\n                        \n                        if (min === fromLeft || min === fromRight) {\n                            this.ball.dx = -this.ball.dx;\n                        } else {\n                            this.ball.dy = -this.ball.dy;\n                        }\n                        \n                        return;\n                    }\n                }\n            }\n        }\n        \n        // 检查与挡板的碰撞\n        if (\n            this.ball.y + this.ball.radius > this.paddle.y &&\n            this.ball.x > this.paddle.x &&\n            this.ball.x < this.paddle.x + this.paddle.width &&\n            this.ball.dy > 0\n        ) {\n            this.playSound('hit');\n            \n            // 根据击中挡板的位置改变反弹角度\n            const hitPosition = (this.ball.x - this.paddle.x) / this.paddle.width;\n            this.ball.dx = 5 * (hitPosition - 0.5); // -2.5 到 2.5\n            this.ball.dy = -Math.abs(this.ball.dy); // 确保向上反弹\n            \n            // 标准化速度\n            const speed = Math.sqrt(this.ball.dx * this.ball.dx + this.ball.dy * this.ball.dy);\n            this.ball.dx = (this.ball.dx / speed) * this.ball.speed;\n            this.ball.dy = (this.ball.dy / speed) * this.ball.speed;\n        }\n        \n        // 检查与墙壁的碰撞\n        if (this.ball.x + this.ball.radius > this.canvas.width || this.ball.x - this.ball.radius < 0) {\n            this.ball.dx = -this.ball.dx;\n            this.playSound('hit');\n        }\n        \n        if (this.ball.y - this.ball.radius < 0) {\n            this.ball.dy = -this.ball.dy;\n            this.playSound('hit');\n        }\n        \n        // 检查小球是否掉落底部\n        if (this.ball.y + this.ball.radius > this.canvas.height) {\n            this.lives--;\n            this.playSound('life');\n            \n            if (this.lives <= 0) {\n                this.gameOver = true;\n                this.gameRunning = false;\n                this.showGameOver();\n            } else {\n                // 重置小球位置\n                this.resetBall();\n            }\n        }\n    }\n    \n    resetBall() {\n        this.ball.x = this.canvas.width / 2;\n        this.ball.y = this.canvas.height - 50;\n        this.ball.dx = 4 * (Math.random() > 0.5 ? 1 : -1);\n        this.ball.dy = -4;\n    }\n    \n    checkLevelComplete() {\n        let allBricksDestroyed = true;\n        \n        for (let c = 0; c < this.brickColumnCount; c++) {\n            for (let r = 0; r < this.brickRowCount; r++) {\n                if (this.bricks[c][r].visible) {\n                    allBricksDestroyed = false;\n                    break;\n                }\n            }\n            if (!allBricksDestroyed) break;\n        }\n        \n        if (allBricksDestroyed) {\n            this.playSound('win');\n            this.level++;\n            \n            // 每升一级增加难度\n            this.ball.speed += 0.5;\n            this.ball.dx *= 1.1;\n            this.ball.dy *= 1.1;\n            \n            // 创建新的方块\n            this.createBricks();\n            \n            // 重置小球位置\n            this.resetBall();\n"},"partialArgs":"{\"path\": \"C:\\\\Users\\\\WH\\\\Desktop\\\\breakout-game\\\\game.js\", \"content\": \"// 打方块游戏 - 主逻辑\\nclass BreakoutGame {\\n    constructor() {\\n        this.canvas = document.getElementById('gameCanvas');\\n        this.ctx = this.canvas.getContext('2d');\\n        \\n        // 游戏状态\\n        this.gameRunning = false;\\n        this.gamePaused = false;\\n        this.gameOver = false;\\n        \\n        // 游戏参数\\n        this.score = 0;\\n        this.lives = 3;\\n        this.level = 1;\\n        this.soundEnabled = true;\\n        \\n        // 挡板参数\\n        this.paddle = {\\n            width: 100,\\n            height: 15,\\n            x: this.canvas.width / 2 - 50,\\n            y: this.canvas.height - 30,\\n            speed: 8,\\n            color: '#4cc9f0'\\n        };\\n        \\n        // 小球参数\\n        this.ball = {\\n     