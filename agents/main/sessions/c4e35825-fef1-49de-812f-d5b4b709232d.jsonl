{"type":"message","id":"16960791","parentId":"2a441ffe","timestamp":"2026-03-03T13:51:30.940Z","message":{"role":"assistant","content":[{"type":"text","text":"现在创建JavaScript游戏文件："},{"type":"toolCall","id":"call_00_Ala7ByqrzDbpFL2ZlRy5Iqlf","name":"write","arguments":{"path":"C:\\Users\\WH\\Desktop\\breakout-game\\game.js","content":"// 打砖块游戏 - JavaScript\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\nconst scoreElement = document.getElementById('score');\nconst livesElement = document.getElementById('lives');\nconst levelElement = document.getElementById('level');\n\n// 游戏变量\nlet score = 0;\nlet lives = 3;\nlet level = 1;\nlet gameRunning = false;\nlet gamePaused = false;\nlet animationId;\n\n// 挡板\nconst paddle = {\n    width: 100,\n    height: 15,\n    x: canvas.width / 2 - 50,\n    y: canvas.height - 30,\n    speed: 8,\n    color: '#4cc9f0'\n};\n\n// 小球\nconst ball = {\n    x: canvas.width / 2,\n    y: canvas.height - 50,\n    radius: 10,\n    speedX: 5,\n    speedY: -5,\n    color: '#f72585',\n    maxSpeed: 8\n};\n\n// 砖块\nconst brickRowCount = 5;\nconst brickColumnCount = 9;\nconst brickWidth = 60;\nconst brickHeight = 20;\nconst brickPadding = 10;\nconst brickOffsetTop = 50;\nconst brickOffsetLeft = 30;\n\n// 创建砖块数组\nconst bricks = [];\nfor (let c = 0; c < brickColumnCount; c++) {\n    bricks[c] = [];\n    for (let r = 0; r < brickRowCount; r++) {\n        bricks[c][r] = {\n            x: c * (brickWidth + brickPadding) + brickOffsetLeft,\n            y: r * (brickHeight + brickPadding) + brickOffsetTop,\n            width: brickWidth,\n            height: brickHeight,\n            status: 1, // 1表示存在，0表示被击碎\n            color: getBrickColor(r)\n        };\n    }\n}\n\n// 根据行数获取砖块颜色\nfunction getBrickColor(row) {\n    const colors = [\n        '#ff6b6b', // 红色\n        '#ff9e6d', // 橙色\n        '#ffd166', // 黄色\n        '#06d6a0', // 绿色\n        '#118ab2'  // 蓝色\n    ];\n    return colors[row % colors.length];\n}\n\n// 鼠标控制\nlet mouseX = 0;\ncanvas.addEventListener('mousemove', (e) => {\n    const rect = canvas.getBoundingClientRect();\n    mouseX = e.clientX - rect.left;\n    if (!gamePaused && gameRunning) {\n        paddle.x = mouseX - paddle.width / 2;\n        \n        // 限制挡板在画布内\n        if (paddle.x < 0) paddle.x = 0;\n        if (paddle.x + paddle.width > canvas.width) {\n            paddle.x = canvas.width - paddle.width;\n        }\n    }\n});\n\n// 键盘控制\ndocument.addEventListener('keydown', (e) => {\n    if (!gamePaused && gameRunning) {\n        if (e.key === 'ArrowLeft' || e.key === 'a') {\n            paddle.x -= paddle.speed;\n            if (paddle.x < 0) paddle.x = 0;\n        }\n        if (e.key === 'ArrowRight' || e.key === 'd') {\n            paddle.x += paddle.speed;\n            if (paddle.x + paddle.width > canvas.width) {\n                paddle.x = canvas.width - paddle.width;\n            }\n        }\n    }\n});\n\n// 绘制挡板\nfunction drawPaddle() {\n    ctx.beginPath();\n    ctx.roundRect(paddle.x, paddle.y, paddle.width, paddle.height, 8);\n    ctx.fillStyle = paddle.color;\n    ctx.fill();\n    ctx.closePath();\n    \n    // 添加光泽效果\n    ctx.beginPath();\n    ctx.roundRect(paddle.x + 2, paddle.y + 2, paddle.width - 4, 5, 4);\n    ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';\n    ctx.fill();\n    ctx.closePath();\n}\n\n// 绘制小球\nfunction drawBall() {\n    ctx.beginPath();\n    ctx.arc(ball.x, ball.y, ball.radius, 0, Math.PI * 2);\n    ctx.fillStyle = ball.color;\n    ctx.fill();\n    ctx.closePath();\n    \n    // 添加高光效果\n    ctx.beginPath();\n    ctx.arc(ball.x - ball.radius * 0.3, ball.y - ball.radius * 0.3, ball.radius * 0.4, 0, Math.PI * 2);\n    ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';\n    ctx.fill();\n    ctx.closePath();\n}\n\n// 绘制砖块\nfunction drawBricks() {\n    for (let c = 0; c < brickColumnCount; c++) {\n        for (let r = 0; r < brickRowCount; r++) {\n            if (bricks[c][r].status === 1) {\n                const brick = bricks[c][r];\n                \n                // 砖块主体\n                ctx.beginPath();\n                ctx.roundRect(brick.x, brick.y, brick.width, brick.height, 4);\n                ctx.fillStyle = brick.color;\n                ctx.fill();\n                ctx.closePath();\n                \n                // 砖块边框\n                ctx.beginPath();\n                ctx.roundRect(brick.x, brick.y, brick.width, brick.height, 4);\n                ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';\n                ctx.lineWidth = 2;\n                ctx.stroke();\n                ctx.closePath();\n                \n                // 砖块内部高光\n                ctx.beginPath();\n                ctx.roundRect(brick.x + 2, brick.y + 2, brick.width - 4, 6, 2);\n                ctx.fillStyle = 'rgba(255, 255, 255, 0.2)';\n                ctx.fill();\n                ctx.closePath();\n            }\n        }\n    }\n}\n\n// 碰撞检测\nfunction collisionDetection() {\n    for (let c = 0; c < brickColumnCount; c++) {\n        for (let r = 0; r < brickRowCount; r++) {\n            const brick = bricks[c][r];\n            if (brick.status === 1) {\n                if (ball.x > brick.x && \n                    ball.x < brick.x + brick.width && \n                    ball.y > brick.y && \n                    ball.y < brick.y + brick.height) {\n                    \n                    // 播放音效（如果有）\n                    playHitSound();\n                    \n                    // 反转Y方向\n                    ball.speedY = -ball.speedY;\n                    brick.status = 0;\n                    \n                    // 增加分数\n                    score += 10;\n                    scoreElement.textContent = score;\n                    \n                    // 检查是否所有砖块都被击碎\n                    if (checkLevelComplete()) {\n                        levelUp();\n                    }\n                }\n            }\n        }\n    }\n}\n\n// 检查关卡是否完成\nfunction checkLevelComplete() {\n    for (let c = 0; c < brickColumnCount; c++) {\n        for (let r = 0; r < brickRowCount; r++) {\n            if (bricks[c][r].status === 1) {\n                return false;\n            }\n        }\n    }\n    return true;\n}\n\n// 升级关卡\nfunction levelUp() {\n    level++;\n    levelElement.textContent = level;\n    \n    // 增加小球速度（但不超过最大速度）\n    ball.speedX = Math.min(Math.abs(ball.speedX) + 0.5, ball.maxSpeed) * (ball.speedX > 0 ? 1 : -1);\n    ball.speedY = Math.min(Math.abs(ball.speedY) + 0.5, ball.maxSpeed) * (ball.speedY > 0 ? 1 : -1);\n    \n    // 重置砖块\n    resetBricks();\n    \n    // 重置小球位置\n    resetBall();\n    \n    // 显示过关消息\n    showMessage(`恭喜过关！等级 ${level}`);\n}\n\n// 重置砖块\nfunction resetBricks() {\n    for (let c = 0; c < brickColumnCount; c++) {\n        for (let r = 0; r < brickRowCount; r++) {\n            bricks[c][r].status = 1;\n        }\n    }\n}\n\n// 重置小球\nfunction resetBall() {\n    ball.x = canvas.width / 2;\n    ball.y = canvas.height - 50;\n    ball.speedY = -Math.abs(ball.speedY);\n}\n\n// 显示消息\nfunction showMessage(text) {\n    ctx.font = '24px Arial';\n    ctx.fillStyle = '#ffd700';\n    ctx.textAlign = 'center';\n    ctx.fillText(text, canvas.width / 2, canvas.height / 2);\n    \n    // 3秒后清除消息\n    setTimeout(() => {\n        if (gameRunning && !gamePaused) {\n            draw();\n        }\n    }, 3000);\n}\n\n// 播放击打音效\nfunction playHitSound() {\n    // 创建简单的音效\n    try {\n        const audioContext = new (window.AudioContext || window.webkitAudioContext)();\n        const oscillator = audioContext.createOscillator();\n        const gainNode = audioContext.createGain();\n        \n        oscillator.connect(gainNode);\n        gainNode.connect(audioContext.destination);\n        \n        oscillator.frequency.value = 800;\n        oscillator.type = 'sine';\n        \n        gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);\n        gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);\n        \n        oscillator.start(audioContext.currentTime);\n        oscillator.stop(audioContext.currentTime + 0.1);\n    } catch (e) {\n        // 如果音效失败，静默处理\n    }\n}\n\n// 绘制游戏\nfunction draw() {\n    // 清除画布\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n    \n    // 绘制背景网格\n    drawBackground();\n    \n    // 绘制所有元素\n    drawBricks();\n    drawBall();\n    drawPaddle();\n    \n    // 碰撞检测\n    collisionDetection();\n    \n    // 小球移动\n    ball.x += ball.speedX;\n    ball.y += ball.speedY;\n    \n    // 墙壁碰撞（左右墙）\n    if (ball.x + ball.radius > canvas.width || ball.x - ball.radius < 0) {\n        ball.speedX = -ball.speedX;\n        playHitSound();\n    }\n    \n    // 墙壁碰撞（上墙）\n    if (ball.y - ball.radius < 0) {\n        ball.speedY = -ball.speedY;\n        playHitSound();\n    }\n    \n    // 挡板碰撞\n    if (ball.y + ball.radius > paddle.y && \n        ball.y - ball.radius < paddle.y + paddle.height &&\n        ball.x > paddle.x && \n        ball.x < paddle.x + paddle.width) {\n        \n        // 根据击中挡板的位置改变反弹角度\n        const hitPosition = (ball.x - paddle.x) / paddle.width;\n        ball.speedX = (hitPosition - 0.5) * 10; // -5 到 5\n        ball.speedY = -Math.abs(ball.speedY);\n        playHitSound();\n    }\n    \n    // 小球掉落底部\n    if (ball.y + ball.radius > canvas.height) {\n        lives--;\n        livesElement.textContent = lives;\n        \n        if (lives <= 0) {\n            gameOver();\n            return;\n        } else {\n            resetBall();\n            showMessage(`损失1点生命！剩余 ${lives} 点`);\n        }\n    }\n    \n    // 继续动画\n    if (gameRunning && !gamePaused) {\n        animationId = requestAnimationFrame(draw);\n    }\n}\n\n// 绘制背景网格\nfunction drawBackground() {\n    ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';\n    ctx.lineWidth = 1;\n    \n    // 垂直线\n    for (let x = 0; x < canvas.width; x += 40) {\n        ctx.beginPath();\n        ctx.moveTo(x, 0);\n        ctx.lineTo(x, canvas.height);\n        ctx.stroke();\n    }\n    \n    // 水平线\n    for (let y = 0; y < canvas.height; y += 40) {\n        ctx.beginPath();\n        ctx.moveTo(0, y);\n        ctx.lineTo(canvas.width, y);\n        ctx.stroke();\n    }\n}\n\n// 游戏结束\nfunction gameOver() {\n    gameRunning = false;\n    ctx.font = '48px Arial';\n    ctx.fillStyle = '#ff6b6b';\n    ctx.textAlign = 'center';\n    ctx.fillText('游戏结束!', canvas.width / 2, canvas.height / 2 - 30);\n    \n    ctx.font = '24px Arial';\n    ctx.fillStyle = '#ffffff';\n    ctx.fillText(`最终得分: ${score}`, canvas.width / 2, canvas.height / 2 + 30);\n}\n\n// 开始游戏\nfunction startGame() {\n    if (!gameRunning) {\n        gameRunning = true;\n        gamePaused = false;\n        score = 0;\n        lives = 3;\n        level = 1;\n        \n        scoreElement.textContent = score;\n        livesElement.textContent = lives;\n        levelElement.textContent = level;\n        \n        resetBricks();\n        resetBall();\n        draw();\n    }\n}\n\n// 暂停/继续游戏\nfunction pauseGame() {\n    if (gameRunning) {\n        gamePaused = !gamePaused;\n        if (!gamePaused) {\n            draw();\n        } else {\n            ctx.font = '36px Arial';\n            ctx.fillStyle = '#ffd700';\n            ctx.textAlign = 'center';\n            ctx.fillText('游戏暂停', canvas.width / 2, canvas.height / 2);\n        }\n    }\n}\n\n// 重新开始游戏\nfunction restartGame() {\n    if (animationId) {\n        cancelAnimationFrame(animationId);\n    }\n    startGame();\n}\n\n// 初始化圆角矩形方法（如果不存在）\nif (!CanvasRenderingContext2D.prototype.roundRect) {\n    CanvasRenderingContext2D.prototype.roundRect = function(x, y, width, height, radius) {\n        if (width < 2 * radius) radius = width / 2;\n        if (height < 2 * radius) radius = height / 2;\n        \n        this.beginPath();\n        this.moveTo(x + radius, y);\n        this.arcTo(x + width, y, x + width, y + height, radius);\n        this.arcTo(x + width, y + height, x, y + height, radius);\n        this.arcTo(x, y + height, x, y, radius);\n        this.arcTo(x, y, x + width, y, radius);\n        this.closePath();\n        return this;\n    };\n}\n\n// 初始绘制\ndrawBackground();\ndrawBricks();\ndrawBall();\ndrawPaddle();\n\n// 显示开始提示\nctx.font = '20px Arial';\nctx.fillStyle = '#4cc9f0';\nctx.textAlign = 'center';\nctx.fillText('点击\"开始游戏\"按钮开始', canvas.width / 2, canvas.height / 2);"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":101,"output":3447,"cacheRead":22720,"cacheWrite":0,"totalTokens":26268,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772545746188}}
