       // 水平线\n        for (let y = 0; y < this.canvas.height; y += 50) {\n            this.ctx.beginPath();\n            this.ctx.moveTo(0, y);\n            this.ctx.lineTo(this.canvas.width, y);\n            this.ctx.stroke();\n        }\n    }\n    \n    drawMenu() {\n        this.ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';\n        this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);\n        \n        this.ctx.fillStyle = '#4cc9f0';\n        this.ctx.font = '48px Arial';\n        this.ctx.textAlign = 'center';\n        this.ctx.fillText('打方块游戏', this.canvas.width / 2, this.canvas.height / 2 - 60);\n        \n        this.ctx.fillStyle = 'white';\n        this.ctx.font = '24px Arial';\n        this.ctx.fillText('点击或按空格键开始游戏', this.canvas.width / 2, this.canvas.height / 2);\n        \n        this.ctx.font = '18px Arial';\n        this.ctx.fillText('使用鼠标或方向键控制挡板', this.canvas.width / 2, this.canvas.height / 2 + 40);\n    }\n    \n    drawPaused() {\n        this.ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';\n        this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);\n        \n        this.ctx.fillStyle = '#ffd166';\n        this.ctx.font = '48px Arial';\n        this.ctx.textAlign = 'center';\n        this.ctx.fillText('游戏暂停', this.canvas.width / 2, this.canvas.height / 2);\n        \n        this.ctx.fillStyle = 'white';\n        this.ctx.font = '20px Arial';\n        this.ctx.fillText('按空格键继续游戏', this.canvas.width / 2, this.canvas.height / 2 + 50);\n    }\n    \n    collisionDetection() {\n        for (let c = 0; c < this.brickColumnCount; c++) {\n            for (let r = 0; r < this.brickRowCount; r++) {\n                const brick = this.bricks[c][r];\n                if (brick.status > 0) {\n                    if (\n                        this.ball.x + this.ball.radius > brick.x &&\n                        this.ball.x - this.ball.radius < brick.x + brick.width &&\n                        this.ball.y + this.ball.radius > brick.y &&\n                        this.ball.y - this.ball.radius < brick.y + brick.height\n                    ) {\n                        // 减少方块生命值\n                        brick.health--;\n                        \n                        if (brick.health <= 0) {\n                            brick.status = 0;\n                            this.score += brick.points;\n                            \n                            // 检查是否所有方块都被击碎\n                            let allBricksDestroyed = true;\n                            for (let c2 = 0; c2 < this.brickColumnCount; c2++) {\n                                for (let r2 = 0; r2 < this.brickRowCount; r2++) {\n                                    if (this.bricks[c2][r2].status > 0) {\n                                        allBricksDestroyed = false;\n                                        break;\n                                    }\n                                }\n                                if (!allBricksDestroyed) break;\n                            }\n                            \n                            if (allBricksDestroyed) {\n                                this.levelUp();\n                            }\n                        }\n                        \n                        // 反弹球\n                        this.ball.speedY = -this.ball.speedY;\n                        \n                        // 播放音效\n                        if (this.soundEnabled) {\n                            this.playSound('brick');\n                        }\n                        \n                        this.updateUI();\n                        return;\n                    }\n                }\n            }\n        }\n    }\n    \n    levelUp() {\n        this.level++;\n        this.ball.speedX *= 1.1;\n        this.ball.speedY *= 1.1;\n        \n        // 限制最大速度\n        this.ball.speedX = Math.min(this.ball.speedX, this.ball.maxSpeed);\n        this.ball.speedY = Math.min(Math.abs(this.ball.speedY), this.ball.maxSpeed) * Math.sign(this.ball.speedY);\n        \n        // 重置球的位置\n        this.ball.x = this.canvas.width / 2;\n        this.ball.y = this.canvas.height - 50;\n        \n        // 生成新的方块\n        this.initBricks();\n        \n        this.updateUI();\n    }\n    \n    update() {\n        if (this.gameState !== 'playing') return;\n        \n        // 键盘控制挡板\n        if (this.rightPressed && this.paddle.x < this.canvas.width - this.paddle.width) {\n            this.paddle.x += this.paddle.speed;\n        } else if (this.leftPressed && this.paddle.x > 0) {\n            this.paddle.x -= this.paddle.speed;\n        }\n        \n        // 更新球的位置\n        this.ball.x += this.ball.speedX;\n        this.ball.y += this.ball.speedY;\n        \n        // 检测墙壁碰撞\n        if (this.ball.x + this.ball.radius > this.canvas.width || this.ball.x - this.ball.radius < 0) {\n            this.ball.speedX = -this.ball.speedX;\n            if (this.soundEnabled) this.playSound('hit');\n        }\n        \n        if (this.ball.y - this.ball.radius < 0) {\n            this.ball.speedY = -this.ball.speedY;\n            if (this.soundEnabled) this.playSound('hit');\n        }\n        \n        // 检测挡板碰撞\n        if (\n            this.ball.y + this.ball.radius > this.paddle.y &&\n            this.ball.y - this.ball.radius < this.paddle.y + this.paddle.height &&\n            this.ball.x + this.ball.radius > this.paddle.x &&\n            this.ball.x - this.ball.radius < this.paddle.x + this.paddle.width\n        ) {\n            // 根据击中挡板的位置改变反弹角度\n            const hitPoint = (this.ball.x - (this.paddle.x + this.paddle.width / 2)) / (this.paddle.width / 2);\n            this.ball.speedX = hitPoint * 6; // 最大偏转角度\n            \n            // 确保垂直速度足够\n            this.ball.speedY = -Math.abs(this.ball.speedY);\n            \n            if (this.soundEnabled) this.playSound('hit');\n        }\n        \n        // 检测球是否掉落\n        if (this.ball.y + this.ball.radius > this.canvas.height) {\n            this.lives--;\n            this.updateUI();\n            \n            if (this.lives <= 0) {\n                this.gameOver();\n            } else {\n                // 重置球的位置\n                this.ball.x = this.canvas.width / 2;\n                this.ball.y = this.canvas.height - 50;\n                this.ball.speedX = 5;\n                this.ball.speedY = -5;\n                \n                if (this.soundEnabled) this.playSound('life');\n            }\n        }\n        \n        // 检测方块碰撞\n        this.collisionDetection();\n    }\n    \n    gameOver() {\n        this.gameState = 'gameOver';\n        document.getElementById('finalScore').textContent = this.score;\n        document.getElementById('gameOverScreen').style"},"partialArgs":"{\"path\": \"C:\\\\Users\\\\WH\\\\Desktop\\\\breakout-game\\\\game.js\", \"content\": \"// 打方块游戏 - 游戏逻辑\\nclass BreakoutGame {\\n    constructor() {\\n        this.canvas = document.getElementById('gameCanvas');\\n        this.ctx = this.canvas.getContext('2d');\\n        \\n        // 游戏状态\\n        this.gameState = 'menu'; // menu, playing, paused, gameOver\\n        this.score = 0;\\n        this.lives = 3;\\n        this.level = 1;\\n        \\n        // 游戏元素\\n        this.paddle = {\\n            x: this.canvas.width / 2 - 75,\\n            y: this.canvas.height - 20,\\n            width: 150,\\n            height: 15,\\n            speed: 8,\\n            color: '#4cc9f0'\\n        };\\n        \\n        this.ball = {\\n            x: this.canvas.width / 2,\\n            y: this.canvas.height - 50,\\n            radius: 10,\\n            speedX: 5,\\n            speedY: -5,\\n            color: '#f72585',\\n            maxSpeed: 8\\n        };\\n        \\n        // 方块设置\\n        this.brickRowCount = 5;\\n        this.brickColumnCount = 10;\\n        this.brickWidth = 70;\\n        this.brickHeight = 20;\\n        this.brickPadding = 10;\\n        this.brickOffsetTop = 60;\\n        this.brickOffsetLeft = 25;\\n        \\n        this.bricks = [];\\n        this.initBricks();\\n        \\n        // 控制\\n        this.rightPressed = false;\\n        this.leftPressed = false;\\n        this.mouseX = 0;\\n        \\n        // 音效\\n        this.soundEnabled = true;\\n        this.sounds = {\\n            hit: new Audio('data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAZGF0YQQAAAAAAA=='),\\n            brick: new Audio('data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAZGF0YQQAAAAAAA=='),\\n            life: new Audio('data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAZGF0YQQAAAAAAA==')\\n        };\\n        \\n        // 绑定事件\\n        this.setupEventListeners();\\n        \\n        // 开始游戏循环\\n        this.gameLoop();\\n    }\\n    \\n    initBricks() {\\n        this.bricks = [];\\n        for (let c = 0; c < this.brickColumnCount; c++) {\\n            this.bricks[c] = [];\\n            for (let r = 0; r < this.brickRowCount; r++) {\\n                // 随机生成不同类型的方块\\n                const brickType = Math.random() > 0.8 ? 'gold' : \\n                                 Math.random() > 0.7 ? 'red' : 'normal';\\n                \\n                let health = 1;\\n                let color = '#4361ee';\\n                let points = 10;\\n                \\n                switch(brickType) {\\n                    case 'red':\\n                        health = 2;\\n                        color = '#f72585';\\n                        points = 15;\\n                        break;\\n                    case 'gold':\\n                        color = '#ffd166';\\n                        points = 20;\\n                        break;\\n                }\\n                \\n                this.bricks[c][r] = {\\n                    x: c * (this.brickWidth + this.brickPadding) + this.brickOffsetLeft,\\n                    y: r * (this.brickHeight + this.brickPadding) + this.brickOffsetTop,\\n                    width: this.brickWidth,\\n                    height: this.brickHeight,\\n                    health: health,\\n                    maxHealth: health,\\n                    color: color,\\n                    points: points,\\n                    status: 1\\n                };\\n            }\\n        }\\n    }\\n    \\n    setupEventListeners() {\\n        // 键盘控制\\n        document.addEventListener('keydown', (e) => {\\n            if (e.key === 'Right' || e.key === 'ArrowRight') {\\n                this.rightPressed = true;\\n            } else if (e.key === 'Left' || e.key === 'ArrowLeft') {\\n                this.leftPressed = true;\\n            } else if (e.key === ' ') {\\n                if (this.gameState === 'menu') {\\n                    this.startGame();\\n                } else if (this.gameState === 'playing') {\\n                    this.pauseGame();\\n                }\\n            }\\n        });\\n        \\n        document.addEventListener('keyup', (e) => {\\n            if (e.key === 'Right' || e.key === 'ArrowRight') {\\n                this.rightPressed = false;\\n            } else if (e.key === 'Left' || e.key === 'ArrowLeft') {\\n                this.leftPressed = false;\\n            }\\n        });\\n        \\n        // 鼠标控制\\n        this.canvas.addEventListener('mousemove', (e) => {\\n            const rect = this.canvas.getBoundingClientRect();\\n            this.mouseX = e.clientX - rect.left;\\n            \\n            if (this.gameState === 'playing') {\\n                // 限制挡板在画布内\\n                this.paddle.x = Math.max(\\n                    0, \\n                    Math.min(\\n                        this.mouseX - this.paddle.width / 2, \\n                        this.canvas.width - this.paddle.width\\n                    )\\n                );\\n            }\\n        });\\n        \\n        this.canvas.addEventListener('click', () => {\\n            if (this.gameState === 'menu') {\\n                this.startGame();\\n            }\\n        });\\n    }\\n    \\n    startGame() {\\n        if (this.gameState === 'menu' || this.gameState === 'gameOver') {\\n            this.resetGame();\\n            this.gameState = 'playing';\\n            document.getElementById('gameOverScreen').style.display = 'none';\\n        }\\n    }\\n    \\n    pauseGame() {\\n        if (this.gameState === 'playing') {\\n            this.gameState = 'paused';\\n        } else if (this.gameState === 'paused') {\\n            this.gameState = 'playing';\\n        }\\n    }\\n    \\n    restartGame() {\\n        this.resetGame();\\n        this.gameState = 'playing';\\n        document.getElementById('gameOverScreen').style.display = 'none';\\n    }\\n    \\n    resetGame() {\\n        this.score = 0;\\n        this.lives = 3;\\n        this.level = 1;\\n        \\n        this.ball.x = this.canvas.width / 2;\\n        this.ball.y = this.canvas.height - 50;\\n        this.ball.speedX = 5;\\n        this.ball.speedY = -5;\\n        \\n        this.paddle.x = this.canvas.width / 2 - this.paddle.width / 2;\\n        \\n        this.initBricks();\\n        \\n        this.updateUI();\\n    }\\n    \\n    updateUI() {\\n        document.getElementById('score').textContent = this.score;\\n        document.getElementById('lives').textContent = this.lives;\\n        document.getElementById('level').textContent = this.level;\\n    }\\n    \\n    drawPaddle() {\\n        this.ctx.beginPath();\\n        this.ctx.roundRect(this.paddle.x, this.paddle.y, this.paddle.width, this.paddle.height, 10);\\n        this.ctx.fillStyle = this.paddle.color;\\n        this.ctx.fill();\\n        this.ctx.closePath();\\n        \\n        // 添加光泽效果\\n        this.ctx.beginPath();\\n        this.ctx.roundRect(this.paddle.x + 2, this.paddle.y + 2, this.paddle.width - 4, 5, 5);\\n        this.ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';\\n        this.ctx.fill();\\n        this.ctx.closePath();\\n    }\\n    \\n    drawBall() {\\n        this.ctx.beginPath();\\n        this.ctx.arc(this.ball.x, this.ball.y, this.ball.radius, 0, Math.PI * 2);\\n        this.ctx.fillStyle = this.ball.color;\\n        this.ctx.fill();\\n        this.ctx.closePath();\\n        \\n        // 添加高光效果\\n        this.ctx.beginPath();\\n        this.ctx.arc(this.ball.x - 3, this.ball.y - 3, 3, 0, Math.PI * 2);\\n        this.ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';\\n        this.ctx.fill();\\n        this.ctx.closePath();\\n    }\\n    \\n    drawBricks() {\\n        for (let c = 0; c < this.brickColumnCount; c++) {\\n            for (let r = 0; r < this.brickRowCount; r++) {\\n                const brick = this.bricks[c][r];\\n                if (brick.status > 0) {\\n                    // 绘制方块主体\\n                    this.ctx.beginPath();\\n                    this.ctx.roundRect(brick.x, brick.y, brick.width, brick.height, 5);\\n                    this.ctx.fillStyle = brick.color;\\n                    this.ctx.fill();\\n                    this.ctx.closePath();\\n                    \\n                    // 绘制方块边框\\n                    this.ctx.beginPath();\\n                    this.ctx.roundRect(brick.x, brick.y, brick.width, brick.height, 5);\\n                    this.ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';\\n                    this.ctx.lineWidth = 2;\\n                    this.ctx.stroke();\\n                    this.ctx.closePath();\\n                    \\n                    // 如果方块有多个生命值，显示生命值\\n                    if (brick.maxHealth > 1) {\\n                        this.ctx.fillStyle = 'white';\\n                        this.ctx.font = '12px Arial';\\n                        this.ctx.textAlign = 'center';\\n                        this.ctx.fillText(\\n                            brick.health, \\n                            brick.x + brick.width / 2, \\n                            brick.y + brick.height / 2 + 4\\n                        );\\n                    }\\n                }\\n            }\\n