t(f\"  {endpoint}: HTTP {response.status_code}\")\n        except requests.exceptions.RequestException as e:\n            print(f\"  {endpoint}: 无法访问 - {e}\")\n\ndef main():\n    \"\"\"主函数\"\"\"\n    print(\"=\" * 60)\n    print(\"豆包API发现工具\")\n    print(\"=\" * 60)\n    \n    check_local_ports()\n    check_config_files()\n    check_known_apis()\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"建议的下一步:\")\n    print(\"1. 打开豆包应用，使用浏览器开发者工具(F12)查看网络请求\")\n    print(\"2. 查看豆包官方文档或开发者平台\")\n    print(\"3. 检查豆包设置中是否有API/开发者选项\")\n    print(\"4. 在豆包官网查找API文档\")\n    print(\"=\" * 60)\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":171,"output":1303,"cacheRead":54528,"cacheWrite":0,"totalTokens":56002,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1771774959582}}
