{"type":"message","id":"cd4948e5","parentId":"0c692d03","timestamp":"2026-02-22T04:12:42.450Z","message":{"role":"toolResult","toolCallId":"call_00_9x8whKiwNEVIDccd46VoDZ65","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nWindows原生语音聊天\n使用Windows自带的语音识别API，无需安装SpeechRecognition\n\"\"\"\n\nimport sys\nimport os\nimport time\nimport threading\nimport queue\nimport subprocess\nfrom datetime import datetime\n\nclass WindowsVoiceChat:\n    def __init__(self):\n        \"\"\"初始化Windows语音聊天\"\"\"\n        self.running = True\n        self.message_queue = queue.Queue()\n        self.config = {\n            'language': 'zh-CN',\n            'log_file': 'windows_voice_chat.log'\n        }\n        \n        self.setup_logging()\n        self.initialize_tts()\n    \n    def setup_logging(self):\n        \"\"\"设置日志\"\"\"\n        self.log_file = self.config['log_file']\n        with open(self.log_file, 'a', encoding='utf-8') as f:\n            f.write(f\"\\n{'='*50}\\n\")\n            f.write(f\"Windows语音聊天启动 - {datetime.now()}\\n\")\n            f.write(f\"{'='*50}\\n\")\n    \n    def log(self, message):\n        \"\"\"记录日志\"\"\"\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        log_message = f\"[{timestamp}] {message}\"\n        \n        print(log_message)\n        with open(self.log_file, 'a', encoding='utf-8') as f:\n            f.write(log_message + \"\\n\")\n    \n    def initialize_tts(self):\n        \"\"\"初始化语音合成\"\"\"\n        self.log(\"初始化语音合成...\")\n        \n        # 尝试pyttsx3\n        try:\n            import pyttsx3\n            self.tts_engine = pyttsx3.init()\n            \n            # 设置中文语音\n            voices = self.tts_engine.getProperty('voices')\n            for voice in voices:\n                if 'chinese' in voice.name.lower() or 'zh' in voice.id.lower():\n                    self.tts_engine.setProperty('voice', voice.id)\n                    self.log(f\"使用语音: {voice.name}\")\n                    break\n            \n            self.tts_engine.setProperty('rate', 150)\n            self.tts_engine.setProperty('volume', 0.9)\n            \n            self.log(\"✓ pyttsx3初始化成功\")\n            self.use_pyttsx3 = True\n        except Exception as e:\n            self.log(f\"pyttsx3初始化失败: {e}\")\n            self.use_pyttsx3 = False\n        \n        # 备用：edge-tts\n        try:\n            import edge_tts\n            self.use_edge_tts = True\n            self.log(\"✓ edge-tts可用\")\n        except ImportError:\n            self.use_edge_tts = False\n    \n    def speak(self, text):\n        \"\"\"语音合成\"\"\"\n        self.log(f\"说话: {text}\")\n        \n        if self.use_pyttsx3:\n            try:\n                self.tts_engine.say(text)\n                self.tts_engine.runAndWait()\n                return True\n            except Exception as e:\n                self.log(f\"pyttsx3错误: {e}\")\n                self.use_pyttsx3 = False\n        \n        if self.use_edge_tts:\n            try:\n                import asyncio\n                import edge_tts\n                import tempfile\n                \n                with tempfile.NamedTemporaryFile(suffix='.mp3', delete=False) as tmp:\n                    temp_file = tmp.name\n                \n                async def generate_speech():\n                    tts = edge_tts.Communicate(text=text, voice=\"zh-CN-XiaoxiaoNeural\")\n                    await tts.save(temp_file)\n                \n                asyncio.run(generate_speech())\n                \n                if os.path.exists(temp_file):\n                    os.startfile(temp_file)\n                    \n                    # 延迟删除文件\n                    def delete_later(path):\n                        time.sleep(10)\n                        try:\n                            os.unlink(path)\n                        except:\n                            pass\n                    \n                    threading.Thread(target=delete_later, args=(temp_file,)).start()\n                    return True\n                    \n            except Exception as e:\n                self.log(f\"edge-tts错误: {e}\")\n        \n        # 最后尝试：Windows PowerShell TTS\n        try:\n            ps_script = f\"\"\"\n            Add-Type -AssemblyName System.speech\n            $speak = New-Object System.Speech.Synthesis.SpeechSynthesizer\n            $speak.Speak(\"{text}\")\n            \"\"\"\n            subprocess.run(['powershell', '-Command', ps_script], capture_output=True)\n            return True\n        except Exception as e:\n            self.log(f\"PowerShell TTS错误: {e}\")\n        \n        return False\n    \n    def listen_windows_speech(self):\n        \"\"\"使用Windows语音识别\"\"\"\n        self.log(\"使用Windows语音识别...\")\n        \n        try:\n            # 创建PowerShell脚本进行语音识别\n            ps_script = \"\"\"\n            Add-Type -AssemblyName System.Speech\n            $recognizer = New-Object System.Speech.Recognition.SpeechRecognitionEngine\n            $grammar = New-Object System.Speech.Recognition.DictationGrammar\n            $recognizer.LoadGrammar($grammar)\n            $recognizer.SetInputToDefaultAudioDevice()\n            \n            Write-Host \"请说话...\" -ForegroundColor Yellow\n            $result = $recognizer.Recognize()\n            \n            if ($result) {\n                Write-Host \"识别结果:\" $result.Text\n                $result.Text\n            } else {\n                Write-Host \"未识别到语音\"\n                \"\"\n            }\n            \"\"\"\n            \n            # 运行PowerShell脚本\n            result = subprocess.run(\n                ['powershell', '-Command', ps_script],\n                capture_output=True,\n                text=True,\n                encoding='utf-8',\n                errors='ignore'\n            )\n            \n            # 解析输出\n            output = result.stdout\n            lines = output.split('\\n')\n            \n            for line in lines:\n                if line.strip() and not line.startswith('请说话') and not line.startswith('识别结果'):\n                    text = line.strip()\n                    if text:\n                        self.log(f\"识别到: {text}\")\n                        return text\n            \n            return None\n            \n        except Exception as e:\n            self.log(f\"Windows语音识别错误: {e}\")\n            return None\n    \n    def listen_alternative(self):\n        \"\"\"备用监听方案：录音并调用在线服务\"\"\"\n        self.log(\"使用备用监听方案...\")\n        \n        try:\n            # 录音\n            import pyaudio\n            import wave\n            import tempfile\n            \n            # 录音参数\n            CHUNK = 1024\n            FORMAT = pyaudio.paInt16\n            CHANNELS = 1\n            RATE = 16000\n            RECORD_SECONDS = 5\n            \n            p = pyaudio.PyAudio()\n            \n            stream = p.open(\n                format=FORMAT,\n                channels=CHANNELS,\n                rate=RATE,\n                input=True,\n                frames_per_buffer=CHUNK\n            )\n            \n            self.log(f\"录音 {RECORD_SECONDS} 秒...\")\n            frames = []\n            \n            for i in range(0, int(RATE / CHUNK * RECORD_SECONDS)):\n                data = stream.read(CHUNK)\n                frames.append(data)\n            \n            stream.stop_stream()\n            stream.close()\n            p.terminate()\n            \n            # 保存录音\n            with tempfile.NamedTemporaryFile(suffix='.wav', delete=False) as tmp:\n                temp_file = tmp.name\n                \n                wf = wave.open(temp_file, 'wb')\n                wf.setnchannels(CHANNELS)\n                wf.setsampwidth(p.get_sample_size(FORMAT))\n                wf.setframerate(RATE)\n                wf.writeframes(b''.join(frames))\n                wf.close()\n            \n            self.log(f\"录音保存到: {temp_file}\")\n            \n            # 这里可以添加调用在线语音识别服务的代码\n            # 例如：Google Cloud Speech-to-Text, Azure Speech等\n            \n            # 暂时返回测试文本\n            return \"这是测试识别结果，实际需要配置在线服务\"\n            \n        except Exception as e:\n            self.log(f\"备用监听错误: {e}\")\n            return None\n    \n    def get_user_input_fallback(self):\n        \"\"\"回退方案：控制台输入\"\"\"\n        self.log(\"使用控制台输入回退方案...\")\n        \n        print(\"\\n\" + \"=\"*50)\n        print(\"Windows语音聊天\")\n        print(\"=\"*50)\n        print(\"选项:\")\n        print(\"1. 测试语音输出\")\n        print(\"2. 输入文字对话\")\n        print(\"3. 退出\")\n        print(\"=\"*50)\n        \n        choice = input(\"\\n请选择 (1-3): \")\n        \n        if choice == '1':\n            return \"测试\"\n        elif choice == '2':\n            user_input = input(\"请输入你想说的话: \")\n            return user_input\n        elif choice == '3':\n            self.running = False\n            return \"退出\"\n        else:\n            return None\n    \n    def process_command(self, text):\n        \"\"\"处理命令\"\"\"\n        if not text:\n            return \"我没有听清楚，请再说一遍\"\n        \n        text_lower = text.lower()\n        \n        if any(word in text_lower for word in ['你好', '嗨', 'hello']):\n            return \"你好！我是OpenClaw Windows语音助手\"\n        \n        elif any(word in text_lower for word in ['测试', '试试']):\n            return \"Windows语音聊天测试成功！我能用语音回复你\"\n        \n        elif any(word in text_lower for word in ['时间', '几点']):\n            current_time = datetime.now().strftime(\"%H点%M分\")\n            return f\"现在时间是 {current_time}\"\n        \n        elif any(word in text_lower for word in ['功能', '能做什么']):\n            return \"我是Windows原生语音聊天程序，使用Windows自带的语音功能，无需额外安装大型库\"\n        \n        elif any(word in text_lower for word in ['退出', '结束', '再见']):\n            self.running = False\n            return \"好的，语音聊天结束，再见！\"\n        \n        elif '测试' in text_lower:\n            return \"测试成功！这是一个Windows原生语音聊天演示\"\n        \n        else:\n            return f\"我听到你说：{text}。这是Windows原生语音聊天演示，未来可以集成更智能的回复\"\n    \n    def run(self):\n        \"\"\"运行主循环\"\"\"\n        self.log(\"启动Windows语音聊天\")\n        self.speak(\"Windows语音聊天已启动\")\n        \n        # 显示菜单\n        print(\"\\n\" + \"=\"*60)\n        print(\"          OpenClaw Windows原生语音聊天\")\n        print(\"=\"*60)\n        print()\n        print(\"功能特点:\")\n        print(\"  • 使用Windows原生语音API\")\n        print(\"  • 无需安装SpeechRecognition大型库\")\n        print(\"  • 支持语音输出和基础交互\")\n        print()\n        print(\"使用说明:\")\n        print(\"  1. 确保麦克风已连接\")\n        print(\"  2. 程序会尝试使用Windows语音识别\")\n        print(\"  3. 如果识别失败，可以使用文字输入\")\n        print(\"  4. 我会用语音回复你\")\n        print()\n        print(\"=\"*60)\n        \n        while self.running:\n            try:\n                # 尝试Windows语音识别\n                user_input = self.listen_windows_speech()\n                \n                # 如果失败，使用回退方案\n                if not user_input:\n                    self.log(\"语音识别失败，使用回退方案\")\n                    user_input = self.get_user_input_fallback()\n                \n                if user_input and user_input.lower() not in ['退出', '结束']:\n                    # 处理并回复\n                    response = self.process_command(user_input)\n                    \n                    if response:\n                        self.speak(response)\n                \n                time.sleep(1)\n                \n            except KeyboardInterrupt:\n                self.log(\"用户中断\")\n                self.running = False\n            except Exception as e:\n                self.log(f\"运行错误: {e}\")\n                time.sleep(2)\n        \n        self.speak(\"Windows语音聊天结束\")\n        self.log(\"程序结束\")\n\ndef main():\n    \"\"\"主函数\"\"\"\n    print(\"启动Windows原生语音聊天...\")\n    print(\"使用Windows自带API，轻量级解决方案\")\n    \n    chat = WindowsVoiceChat()\n    chat.run()\n    \n    print(\"\\n程序已结束\")\n    print(\"要获得更准确的语音识别，建议:\")\n