se\n    \n    def show_menu(self):\n        \"\"\"显示菜单\"\"\"\n        print(\"\\n\" + \"=\" * 60)\n        print(\"          OpenClaw 语音聊天系统\")\n        print(\"=\" * 60)\n        print(\"功能:\")\n        print(\"  1. 语音问候\")\n        print(\"  2. 询问时间\")\n        print(\"  3. 测试对话\")\n        print(\"  4. 自由聊天\")\n        print(\"  5. 退出\")\n        print(\"=\" * 60)\n    \n    def process_choice(self, choice):\n        \"\"\"处理用户选择\"\"\"\n        if choice == '1':\n            return \"你好！我是OpenClaw语音助手，很高兴为你服务\"\n        elif choice == '2':\n            current_time = datetime.now().strftime(\"%H点%M分\")\n            return f\"现在时间是 {current_time}\"\n        elif choice == '3':\n            return \"语音聊天测试成功！我能用语音回复你的输入\"\n        elif choice == '4':\n            user_input = input(\"\\n请输入你想说的话: \")\n            if user_input.lower() in ['退出', '结束', '再见']:\n                self.running = False\n                return \"好的，语音聊天结束，再见！\"\n            else:\n                return f\"我收到你说：{user_input}。这是一个语音聊天演示\"\n        elif choice == '5':\n            self.running = False\n            return \"语音聊天结束，再见！\"\n        else:\n            return \"请选择有效的选项 (1-5)\"\n    \n    def run(self):\n        \"\"\"运行主程序\"\"\"\n        print(\"\\n启动语音聊天系统...\")\n        \n        if self.tts_available:\n            self.speak(\"语音聊天系统已启动\")\n        else:\n            print(\"[WARN] 语音输出不可用，仅显示文字\")\n        \n        while self.running:\n            try:\n                self.show_menu()\n                \n                choice = input(\"\\n请选择功能 (1-5): \").strip()\n                \n                if choice:\n                    response = self.process_choice(choice)\n                    \n                    if response:\n                        print(f\"\\n回复: {response}\")\n                        self.speak(response)\n                    \n                    # 短暂暂停\n                    time.sleep(1)\n                \n            except KeyboardInterrupt:\n                print(\"\\n用户中断\")\n                self.running = False\n                self.speak(\"语音聊天被中断\")\n            except Exception as e:\n                print(f\"[ERROR] 运行错误: {e}\")\n                time.sleep(2)\n        \n        print(\"\\n语音聊天已结束\")\n\ndef main():\n    \"\"\"主函数\"\"\"\n    print(\"OpenClaw 语音聊天系统 - 简化版\")\n    print(\"说明: 使用文字输入，语音输出\")\n    print(\"确保电脑音量已打开\")\n    \n    chat = WorkingVoiceChat()\n    chat.run()\n    \n    print(\"\\n感谢使用！\")\n    print(\"要升级为完整语音识别，需要配置麦克风和网络连接\")\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":68,"output":1094,"cacheRead":32384,"cacheWrite":0,"totalTokens":33546,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1771733692128}}
