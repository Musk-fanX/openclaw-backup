s;\n  },\n  \n  // 全局方法：获取所有待办\n  getTodos() {\n    return wx.getStorageSync('todos') || [];\n  },\n  \n  // 全局方法：获取统计信息\n  getStats() {\n    const todos = wx.getStorageSync('todos') || [];\n    const total = todos.length;\n    const completed = todos.filter(todo => todo.completed).length;\n    const pending = total - completed;\n    \n    return {\n      total,\n      completed,\n      pending,\n      completionRate: total > 0 ? Math.round((completed / total) * 100) : 0\n    };\n  }\n});"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":62,"output":703,"cacheRead":24256,"cacheWrite":0,"totalTokens":25021,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1771687150491}}
