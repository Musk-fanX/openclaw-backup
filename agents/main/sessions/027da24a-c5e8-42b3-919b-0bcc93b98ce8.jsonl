{"type":"message","id":"7b0090f4","parentId":"ddc39914","timestamp":"2026-02-21T16:00:10.703Z","message":{"role":"assistant","content":[{"type":"text","text":"我还在！刚才在运行一些命令检查语音识别库。让我直接为你创建真正的语音聊天插件。\n\n## 🎤 创建真正的语音聊天插件\n\n既然网页自动播放已经工作，现在让我们升级到**真正的语音聊天插件**。\n\n### 第一步：创建语音聊天Python程序"},{"type":"toolCall","id":"call_00_cMbUGLzwLjC7VHytwnBeGajr","name":"write","arguments":{"path":"C:\\Users\\WH\\Desktop\\OpenClaw_Voice\\voice_chat_plugin.py","content":"#!/usr/bin/env python3\n\"\"\"\nOpenClaw 语音聊天插件\n实现真正的语音对话：你说 → 我听 → 我回复 → 你听\n\"\"\"\n\nimport sys\nimport os\nimport json\nimport time\nimport threading\nimport queue\nimport subprocess\nfrom datetime import datetime\n\n# 尝试导入语音识别库\ntry:\n    import speech_recognition as sr\n    SPEECH_RECOGNITION_AVAILABLE = True\nexcept ImportError:\n    SPEECH_RECOGNITION_AVAILABLE = False\n    print(\"警告: 未安装speech_recognition库\")\n\n# 尝试导入pyttsx3（本地TTS）\ntry:\n    import pyttsx3\n    PYTTSX3_AVAILABLE = True\nexcept ImportError:\n    PYTTSX3_AVAILABLE = False\n\nclass VoiceChatPlugin:\n    def __init__(self):\n        \"\"\"初始化语音聊天插件\"\"\"\n        self.running = False\n        self.recognizer = None\n        self.microphone = None\n        self.tts_engine = None\n        self.message_queue = queue.Queue()\n        \n        # 配置\n        self.config = {\n            'language': 'zh-CN',\n            'energy_threshold': 300,  # 语音检测灵敏度\n            'pause_threshold': 0.8,   # 停顿时间阈值\n            'timeout': 5,             # 录音超时时间\n            'phrase_time_limit': 10,  # 单次录音最大时长\n            'use_wake_word': False,   # 是否使用唤醒词\n            'wake_word': 'openclaw',  # 唤醒词\n            'log_file': 'voice_chat.log'\n        }\n        \n        self.setup_logging()\n        self.initialize_components()\n        \n    def setup_logging(self):\n        \"\"\"设置日志\"\"\"\n        self.log_file = self.config['log_file']\n        with open(self.log_file, 'a', encoding='utf-8') as f:\n            f.write(f\"\\n{'='*50}\\n\")\n            f.write(f\"语音聊天插件启动 - {datetime.now()}\\n\")\n            f.write(f\"{'='*50}\\n\")\n    \n    def log(self, message):\n        \"\"\"记录日志\"\"\"\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        log_message = f\"[{timestamp}] {message}\"\n        \n        print(log_message)\n        with open(self.log_file, 'a', encoding='utf-8') as f:\n            f.write(log_message + \"\\n\")\n    \n    def initialize_components(self):\n        \"\"\"初始化语音组件\"\"\"\n        self.log(\"初始化语音组件...\")\n        \n        # 初始化语音识别\n        if SPEECH_RECOGNITION_AVAILABLE:\n            try:\n                self.recognizer = sr.Recognizer()\n                self.microphone = sr.Microphone()\n                \n                # 调整环境噪音\n                with self.microphone as source:\n                    self.log(\"正在调整环境噪音，请保持安静...\")\n                    self.recognizer.adjust_for_ambient_noise(source, duration=1)\n                    self.log(f\"环境噪音阈值: {self.recognizer.energy_threshold}\")\n                \n                self.log(\"✓ 语音识别初始化成功\")\n            except Exception as e:\n                self.log(f\"✗ 语音识别初始化失败: {e}\")\n                self.recognizer = None\n                self.microphone = None\n        else:\n            self.log(\"⚠ speech_recognition库未安装，将使用备用方案\")\n        \n        # 初始化语音合成\n        if PYTTSX3_AVAILABLE:\n            try:\n                self.tts_engine = pyttsx3.init()\n                \n                # 设置语音属性\n                voices = self.tts_engine.getProperty('voices')\n                for voice in voices:\n                    if 'chinese' in voice.name.lower() or 'zh' in voice.id.lower():\n                        self.tts_engine.setProperty('voice', voice.id)\n                        self.log(f\"使用中文语音: {voice.name}\")\n                        break\n                \n                # 设置语速和音量\n                self.tts_engine.setProperty('rate', 150)  # 语速\n                self.tts_engine.setProperty('volume', 0.9)  # 音量\n                \n                self.log(\"✓ 语音合成初始化成功\")\n            except Exception as e:\n                self.log(f\"✗ 语音合成初始化失败: {e}\")\n                self.tts_engine = None\n        else:\n            self.log(\"⚠ pyttsx3库未安装，将使用系统TTS\")\n    \n    def speak(self, text):\n        \"\"\"语音合成 - 我说\"\"\"\n        self.log(f\"语音合成: {text}\")\n        \n        if self.tts_engine and PYTTSX3_AVAILABLE:\n            try:\n                self.tts_engine.say(text)\n                self.tts_engine.runAndWait()\n                return True\n            except Exception as e:\n                self.log(f\"语音合成错误: {e}\")\n                return False\n        else:\n            # 使用系统TTS备用方案\n            try:\n                self.log(\"使用系统TTS备用方案...\")\n                \n                # Windows系统TTS\n                if sys.platform == 'win32':\n                    import win32com.client\n                    speaker = win32com.client.Dispatch(\"SAPI.SpVoice\")\n                    speaker.Speak(text)\n                    return True\n                else:\n                    # 其他系统使用espeak\n                    subprocess.run(['espeak', text], check=False)\n                    return True\n            except Exception as e:\n                self.log(f\"备用TTS也失败: {e}\")\n                \n                # 最后尝试：保存为文件然后用播放器播放\n                self.save_and_play_tts(text)\n                return False\n    \n    def save_and_play_tts(self, text):\n        \"\"\"保存TTS为文件并播放（备用方案）\"\"\"\n        try:\n            # 生成文件名\n            timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n            filename = f\"tts_{timestamp}.wav\"\n            \n            # 使用edge-tts生成音频\n            cmd = [\n                'edge-tts',\n                '--voice', 'zh-CN-XiaoxiaoNeural',\n                '--text', text,\n                '--write-media', filename\n            ]\n            \n            subprocess.run(cmd, capture_output=True, text=True, check=False)\n            \n            if os.path.exists(filename):\n                # 播放音频\n                if sys.platform == 'win32':\n                    os.startfile(filename)\n                else:\n                    subprocess.run(['xdg-open', filename], check=False)\n                \n                self.log(f\"已保存并播放: {filename}\")\n                return True\n            else:\n                self.log(\"生成TTS文件失败\")\n                return False\n                \n        except Exception as e:\n            self.log(f\"保存播放TTS失败: {e}\")\n            return False\n    \n    def listen(self):\n        \"\"\"语音识别 - 我听\"\"\"\n        if not self.recognizer or not self.microphone:\n            self.log(\"语音识别不可用\")\n            return None\n        \n        try:\n            self.log(\"正在聆听...\")\n            \n            with self.microphone as source:\n                # 监听麦克风\n                audio = self.recognizer.listen(\n                    source,\n                    timeout=self.config['timeout'],\n                    phrase_time_limit=self.config['phrase_time_limit']\n                )\n            \n            self.log(\"识别中...\")\n            \n            # 使用Google语音识别\n            try:\n                text = self.recognizer.recognize_google(audio, language=self.config['language'])\n                self.log(f\"识别结果: {text}\")\n                return text\n            except sr.UnknownValueError:\n                self.log(\"无法识别语音\")\n                return None\n            except sr.RequestError as e:\n                self.log(f\"语音识别服务错误: {e}\")\n                return None\n                \n        except Exception as e:\n            self.log(f\"监听过程错误: {e}\")\n            return None\n    \n    def process_command(self, text):\n        \"\"\"处理识别到的文本命令\"\"\"\n        if not text:\n            return \"抱歉，我没有听清楚，请再说一遍\"\n        \n        self.log(f\"处理命令: {text}\")\n        \n        # 简单命令处理\n        text_lower = text.lower()\n        \n        if any(word in text_lower for word in ['你好', '嗨', 'hello', 'hi']):\n            return \"你好！我是OpenClaw，很高兴能用语音和你聊天！\"\n        \n        elif any(word in text_lower for word in ['时间', '几点', '钟']):\n            current_time = datetime.now().strftime(\"%Y年%m月%d日 %H点%M分\")\n            return f\"现在时间是 {current_time}\"\n        \n        elif any(word in text_lower for word in ['天气', '气温']):\n            return \"我目前无法获取实时天气信息，但你可以问我其他问题\"\n        \n        elif any(word in text_lower for word in ['谢谢', '感谢']):\n            return \"不客气！随时为你服务\"\n        \n        elif any(word in text_lower for word in ['再见', '拜拜', '退出']):\n            return \"好的，再见！需要时随时叫我\"\n        \n        elif any(word in text_lower for word in ['名字', '叫什么']):\n            return \"我是OpenClaw，你的智能语音助手\"\n        \n        elif any(word in text_lower for word in ['功能', '能做什么']):\n            return \"我可以和你语音聊天，回答简单问题，告诉你时间等。未来还会增加更多功能！\"\n        \n        else:\n            # 默认回复\n            return f\"我听到你说：{text}。这是一个语音聊天测试，未来我会更智能地回答你的问题\"\n    \n    def chat_loop(self):\n        \"\"\"主聊天循环\"\"\"\n        self.log(\"进入语音聊天循环\")\n        self.speak(\"语音聊天插件已启动，请说话...\")\n        \n        while self.running:\n            try:\n                # 监听用户语音\n                user_speech = self.listen()\n                \n                if user_speech:\n                    # 处理并回复\n                    response = self.process_command(user_speech)\n                    \n                    if response:\n                        self.speak(response)\n                \n                # 短暂暂停\n                time.sleep(0.5)\n                \n            except KeyboardInterrupt:\n                self.log(\"用户中断\")\n                break\n            except Exception as e:\n                self.log(f\"聊天循环错误: {e}\")\n                time.sleep(1)\n    \n    def start(self):\n        \"\"\"启动语音聊天\"\"\"\n        self.log(\"启动语音聊天插件\")\n        self.running = True\n        \n        # 检查依赖\n        if not SPEECH_RECOGNITION_AVAILABLE:\n            self.log(\"重要: 需要安装speech_recognition库\")\n            self.log(\"请运行: pip install SpeechRecognition\")\n            self.log(\"还需要: pip install pyaudio (用于麦克风访问)\")\n        \n        if not PYTTSX3_AVAILABLE:\n            self.log(\"建议安装pyttsx3以获得更好的语音合成\")\n            self.log(\"请运行: pip install pyttsx3\")\n        \n        # 启动聊天线程\n        chat_thread = threading.Thread(target=self.chat_loop)\n        chat_thread.daemon = True\n        chat_thread.start()\n        \n        self.log(\"语音聊天已启动，按Ctrl+C停止\")\n        \n        # 保持主线程运行\n        try:\n            while self.running:\n                time.sleep(1)\n        except KeyboardInterrupt:\n            self.stop()\n    \n    def stop(self):\n        \"\"\"停止语音聊天\"\"\"\n        self.log(\"停止语音聊天插件\")\n        self.running = False\n        self.speak(\"语音聊天结束，再见！\")\n        \n        if self.tts_engine:\n            self.tts_engine.stop()\n\ndef check_dependencies():\n    \"\"\"检查依赖并安装\"\"\"\n    print(\"检查语音聊天插件依赖...\")\n    \n    dependencies = [\n        ('SpeechRecognition', 'speech_recognition'),\n        ('pyttsx3', 'pyttsx3'),\n        ('pyaudio', 'pyaudio')\n    ]\n    \n    missing = []\n    \n    for display_name, module_name in dependencies:\n        try:\n            __import__(module_name)\n            print(f\"✓ {display_name} 已安装\")\n        except ImportError:\n            print(f\"✗ {display_name} 未安装\")\n            missing.append(module_name)\n    \n    if missing:\n        print(\"\\n需要安装以下依赖:\")\n        for module in missing:\n            print(f\"  pip install {module}\")\n        \n        choice = input(\"\\n是否自动安装？(y/n): \")\n        if choice.lower() == 'y':\n            for module in missing:\n                print(f\"安装 {module}...\")\n                subprocess.run([sys.executable, '-m', 'pip', 'install', module], check=False)\n    \n    return len(missing) == 0\n\ndef main():\n    \"\"\"主函数\"\"\"\n    print(\"=\" * 50)\n    print(\"OpenClaw 语音聊天插件\")\n    print(\"=\" * 50)\n    print(\"实现真正的语音对话体验\")\n    print()\n    \n    # 检查依赖\n    if not check_dependencies():\n        print(\"\\n部分依赖缺失，功能可能受限\")\n        print(\"按任意键继续...\")\n        input()\n    \n    # 创建插件实例\n    plugin = VoiceChatPlugin()\n    \n    try:\n        # 启动插件\n        plugin.start()\n    except Exception as e:\n        print(f\"插件运行错误: {e}\")\n    finally:\n        print(\"\\n语音聊天插件已退出\")\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":272,"output":3051,"cacheRead":74432,"cacheWrite":0,"totalTokens":77755,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1771689552880}}
