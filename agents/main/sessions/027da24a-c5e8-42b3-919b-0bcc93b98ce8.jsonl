"btn btn-primary\" bindtap=\"goToTodo\" style=\"flex: 1; margin-right: 10rpx;\">\n        <text>查看所有待办</text>\n      </button>\n      <button class=\"btn btn-secondary\" bindtap=\"addRandomTodo\" style=\"flex: 1; margin-left: 10rpx;\">\n        <text>添加示例</text>\n      </button>\n    </view>\n  </view>\n\n  <!-- 最近待办 -->\n  <view class=\"card fade-in\" style=\"animation-delay: 0.3s;\">\n    <view class=\"flex-between\">\n      <text class=\"subtitle\">最近待办</text>\n      <text class=\"text-muted\" bindtap=\"goToTodo\">查看全部 ></text>\n    </view>\n    \n    <view wx:if=\"{{recentTodos.length > 0}}\">\n      <view wx:for=\"{{recentTodos}}\" wx:key=\"id\" class=\"todo-item\" style=\"padding: 24rpx 0; border-bottom: 2rpx solid #f5f5f5;\">\n        <view class=\"flex-between\">\n          <view class=\"flex\" style=\"align-items: center;\">\n            <view \n              style=\"width: 40rpx; height: 40rpx; border-radius: 50%; border: 4rpx solid {{item.completed ? '#4CAF50' : '#e0e0e0'}}; margin-right: 20rpx; display: flex; align-items: center; justify-content: center;\"\n              bindtap=\"toggleTodo\" data-id=\"{{item.id}}\"\n            >\n              <text wx:if=\"{{item.completed}}\" style=\"color: #4CAF50; font-size: 24rpx;\">✓</text>\n            </view>\n            <text style=\"text-decoration: {{item.completed ? 'line-through' : 'none'}}; color: {{item.completed ? '#999' : '#333'}};\">\n              {{item.text}}\n            </text>\n          </view>\n          <text class=\"text-muted\" style=\"font-size: 24rpx;\">\n            {{formatDate(item.createdAt)}}\n          </text>\n        </view>\n      </view>\n    </view>\n    \n    <view wx:else class=\"flex-column flex-center\" style=\"padding: 60rpx 0;\">\n      <text class=\"text-muted\">暂无待办事项</text>\n      <button class=\"btn btn-primary mt-20\" bindtap=\"addRandomTodo\">\n        <text>添加第一个待办</text>\n      </button>\n    </view>\n  </view>\n\n  <!-- 功能提示 -->\n  <view class=\"card fade-in\" 