'#f0f9f0' : 'transparent'}}\"\n      >\n        已完成 ({{stats.completed}})\n      </text>\n    </view>\n  </view>\n\n  <!-- 待办列表 -->\n  <view wx:if=\"{{filteredTodos.length > 0}}\">\n    <view wx:for=\"{{filteredTodos}}\" wx:key=\"id\" class=\"card todo-item\">\n      <view class=\"flex-between\">\n        <view class=\"flex\" style=\"align-items: center; flex: 1;\">\n          <view \n            style=\"width: 40rpx; height: 40rpx; border-radius: 50%; border: 4rpx solid {{item.completed ? '#4CAF50' : '#e0e0e0'}}; margin-right: 20rpx; display: flex; align-items: center; justify-content: center;\"\n            bindtap=\"toggleTodo\" data-id=\"{{item.id}}\"\n          >\n            <text wx:if=\"{{item.completed}}\" style=\"color: #4CAF50; font-size: 24rpx;\">✓</text>\n          </view>\n          <text style=\"text-decoration: {{item.completed ? 'line-through' : 'none'}}; color: {{item.completed ? '#999' : '#333'}}; flex: 1;\">\n            {{item.text}}\n          </text>\n        </view>\n        <view class=\"flex\" style=\"align-items: center;\">\n          <text class=\"text-muted\" style=\"font-size: 24rpx; margin-right: 20rpx;\">\n            {{formatDate(item.createdAt)}}\n          </text>\n          <text class=\"text-muted\" style=\"font-size: 36rpx; padding: 0 10rpx;\" bindtap=\"deleteTodo\" data-id=\"{{item.id}}\">\n            ×\n          </text>\n        </view>\n      </view>\n    </view>\n  </view>\n\n  <!-- 空状态 -->\n  <view wx:else class=\"card\">\n    <view class=\"flex-column flex-center\" style=\"padding: 80rpx 0;\">\n      <text class=\"text-muted\" style=\"font-size: 32rpx; margin-bottom: 20rpx;\">\n        {{getEmptyMessage()}}\n      </text>\n      <button wx:if=\"{{filter === 'all'}}\" class=\"btn btn-primary\" bindtap=\"addExampleTodos\">\n        <text>添加示例待办</text>\n      </button>\n      <button wx:else class=\"btn btn-secondary\" bindtap=\"setFilter\" data-filter=\"all\">\n        <text>查看全部待办</text>\n      </button>\n    </view>\n  </view>\n\n  <!-- 批量操作 -->\n  <view wx:if=\"{{todos.length > 0}}\" class=\"card\">\n    <view class=\"flex-between\">\n      <button class=\"btn btn-secondary\" bindtap=\"clearCompleted\" disabled=\"{{stats.completed === 0}}\">\n        <text>清除已完成</text>\n      </button>\n      <button class=\"btn btn-secondary\" bindtap=\"markAllAsComplete\">\n        <text>全部完成</text>\n      </button>\n      <button class=\"btn btn-secondary\" bindtap=\"markAllAsIncomplete\">\n        <text>全部重置</text>\n      </button>\n    </view>\n  </view>\n</view>"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":114,"output":1278,"cacheRead":29312,"cacheWrite":0,"totalTokens":30704,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1771687245713}}
