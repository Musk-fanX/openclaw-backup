  font-size: 28rpx;\n  }\n}\n\n/* 暗色模式支持 */\n@media (prefers-color-scheme: dark) {\n  page {\n    background-color: #1a1a1a;\n    color: #e0e0e0;\n  }\n  \n  .card {\n    background: #2d2d2d;\n    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);\n  }\n  \n  .text-muted {\n    color: #888;\n  }\n  \n  .input {\n    background: #333;\n    border-color: #444;\n    color: #e0e0e0;\n  }\n  \n  .input:focus {\n    border-color: #4CAF50;\n  }\n  \n  .btn-secondary {\n    background: #444;\n    color: #bbb;\n  }\n  \n  .btn-secondary:active {\n    background: #555;\n  }\n}"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-chat","usage":{"input":86,"output":861,"cacheRead":28288,"cacheWrite":0,"totalTokens":29235,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1771687226060}}
